{
    "code-runner.runInTerminal": true,
    "explorer.confirmDelete": false,
    "editor.tokenColorCustomizations": {
        "comments": "#3ea947",
        "textMateRules": [
            {
                "scope": [
                    "storage.type",
                    "storage.modifier"
                ],
                "settings": {
                    "foreground": "#639ff9"
                }
            },
            {
                "scope": "entity.name.function",
                "settings": {
                    "foreground": "#fffaa1"
                }
            },
            {
                "scope": "keyword.operator",
                "settings": {
                    "foreground": "#cbeeff"
                }
            },
            {
                "scope": "keyword.control",
                "settings": {
                    "foreground": "#fb99fe"
                }
            },
            {
                "scope": "keyword.other",
                "settings": {
                    "foreground": "#6eb4ff"
                }
            },
            {
                "scope": [
                    "variable",
                    "variable.other"
                ],
                "settings": {
                    "foreground": "#aedfff"
                }
            },
            {
                "scope": "string",
                "settings": {
                    "foreground": "#fe7459"
                }
            }
        ]
    }
}